# Initialize default settings (only if not already set)
execute unless data storage backpack:config cooldown run data modify storage backpack:config cooldown set value 20
execute unless data storage backpack:config combat_block run data modify storage backpack:config combat_block set value 0
execute unless data storage backpack:config drop_on_death run data modify storage backpack:config drop_on_death set value 0
execute unless data storage backpack:config keep_on_death run data modify storage backpack:config keep_on_death set value 1
